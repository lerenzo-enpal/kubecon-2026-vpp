<div class="grid grid-cols-1 md:grid-cols-3 gap-3 my-6">
  <a href={url("/research/incidents/2016-south-australia-blackout")} class="p-4 rounded-lg no-underline hover:opacity-80 transition-opacity" style="background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);">
    <div class="font-mono text-xs mb-1" style="color: var(--color-danger);">Blackout</div>
    <div class="font-semibold text-sm" style="color: var(--color-text);">2016 South Australia Blackout</div>
    <div class="text-xs mt-1" style="color: var(--color-text-dim);">The crisis that created this battery</div>
  </a>
  <a href={url("/research/incidents/2021-texas-ercot-winter-storm")} class="p-4 rounded-lg no-underline hover:opacity-80 transition-opacity" style="background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);">
    <div class="font-mono text-xs mb-1" style="color: var(--color-danger);">Blackout</div>
    <div class="font-semibold text-sm" style="color: var(--color-text);">2021 Texas Winter Storm</div>
    <div class="text-xs mt-1" style="color: var(--color-text-dim);">What happens without fast response</div>
  </a>
  <a href={url("/research/incidents/2017-south-australia-heatwave")} class="p-4 rounded-lg no-underline hover:opacity-80 transition-opacity" style="background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);">
    <div class="font-mono text-xs mb-1" style="color: var(--color-danger);">Blackout</div>
    <div class="font-semibold text-sm" style="color: var(--color-text);">2017 SA Heatwave</div>
    <div class="text-xs mt-1" style="color: var(--color-text-dim);">The crisis that accelerated commissioning</div>
  </a>
</div>

