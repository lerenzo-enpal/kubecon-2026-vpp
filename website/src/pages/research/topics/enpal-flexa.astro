  </a>
  <a href={url("/research/topics/german-grid-curtailment")} class="p-4 rounded-lg no-underline block" style="background: var(--color-surface); border: 1px solid var(--color-surface-light);">
    <div class="font-mono text-sm font-bold" style="color: var(--color-accent);">German Grid Curtailment</div>
    <div class="text-sm mt-1" style="color: var(--color-text-dim);">The problem Flexa helps solve</div>
  </a>
</div>

</ContentLayout>
