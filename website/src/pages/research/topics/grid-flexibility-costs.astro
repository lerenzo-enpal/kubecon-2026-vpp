  </a>
  <a href={url("/research/topics/demand-response")} class="p-4 rounded-lg no-underline block" style="background: var(--color-surface); border: 1px solid var(--color-surface-light);">
    <div class="font-mono text-sm font-bold" style="color: var(--color-success);">Demand Response</div>
