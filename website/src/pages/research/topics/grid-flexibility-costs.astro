<div class="grid grid-cols-1 md:grid-cols-3 gap-4 my-4">
  <a href={url("/research/topics/german-grid-curtailment")} class="p-4 rounded-lg no-underline block" style="background: var(--color-surface); border: 1px solid var(--color-surface-light);">
