---
import BaseLayout from '../layouts/BaseLayout.astro';

import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../utils/url';

const modules = [
  { num: 1, title: 'How the Grid Works', desc: 'The 50 Hz heartbeat, supply = demand, and the 2.5 Hz between normal and collapse.', href: url('/learn/how-the-grid-works'), interactive: true },
  { num: 2, title: 'The Old Way', desc: 'Peaker plants, spinning reserves, and EUR 10B+/yr to keep the lights on.', href: url('/learn/the-old-way'), interactive: true },
  { num: 3, title: 'The Renewable Revolution', desc: 'Duck curves, curtailment, and throwing away clean energy.', href: url('/learn/the-renewable-revolution'), interactive: true },
  { num: 4, title: 'The Virtual Power Plant', desc: 'Homes as infrastructure. Batteries, EVs, and heat pumps stabilizing the grid.', href: url('/learn/the-virtual-power-plant'), interactive: true },
  { num: 5, title: 'The Future', desc: 'Grid resilience through distribution. Software eating the grid.', href: url('/learn/the-future'), interactive: false },
];
---

<BaseLayout title="What is a Virtual Power Plant?">
  <div class="min-h-screen flex flex-col">
    <SiteHeader />

    <main class="flex-1 px-8 py-12">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

          <div>
            <h1 class="text-5xl font-extrabold leading-tight mb-4" style="color: var(--color-text);">
              How does the electricity grid <span style="color: var(--color-primary);">actually</span> work?
            </h1>
            <p class="text-lg mb-10" style="color: var(--color-text-muted); max-width: 520px; line-height: 1.7;">
              The grid is the largest machine ever built. It runs at exactly 50 Hz — and 2.5 Hz
              separates normal from total collapse. Learn how it works, why it's changing, and what
              comes next.
            </p>

            <div class="flex flex-col gap-3">
              {modules.map((m) => (
                <a
                  href={m.href}
                  class="group flex items-start gap-4 p-4 rounded-lg transition-all duration-200 hover:translate-x-1"
                  style="background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);"
                >
                  <div
                    class="flex-shrink-0 w-8 h-8 rounded flex items-center justify-center font-mono font-bold text-sm"
                    style="background: var(--color-surface); color: var(--color-primary);"
                  >
                    {m.num}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="font-semibold group-hover:text-white transition-colors" style="color: var(--color-text);">
                        {m.title}
                      </span>
                      {m.interactive && (
                        <span
                          class="font-mono text-xs px-2 py-0.5 rounded"
                          style="background: rgba(34, 211, 238, 0.1); color: var(--color-primary); border: 1px solid rgba(34, 211, 238, 0.2);"
                        >
                          Interactive
                        </span>
                      )}
                    </div>
                    <div class="text-sm" style="color: var(--color-text-dim);">
                      {m.desc}
                    </div>
                  </div>
                </a>
              ))}
            </div>

          </div>

          <div class="flex flex-col gap-5">
            {/* Conference Talk */}
            <a
              href={url("/slides/")}
              class="block p-5 rounded-lg transition-opacity hover:opacity-90"
              style="background: linear-gradient(135deg, rgba(34, 211, 238, 0.12), rgba(16, 185, 129, 0.08)); border: 1px solid rgba(34, 211, 238, 0.3);"
            >
              <div class="flex items-center gap-3 mb-2">
                <div class="w-2 h-2 rounded-full animate-pulse" style="background: var(--color-primary); box-shadow: 0 0 8px var(--color-primary);"></div>
                <span class="font-mono text-xs font-bold tracking-widest uppercase" style="color: var(--color-primary);">Conference Talk</span>
              </div>
              <div class="text-lg font-bold mb-1" style="color: var(--color-text);">
                Virtual Power Plants — KubeCon Europe 2026
              </div>
              <div class="text-sm mb-3" style="color: var(--color-text-muted);">
                Tuesday, March 25 — Cloud-native infrastructure for the energy grid.
              </div>
              <span class="font-mono text-sm font-semibold" style="color: var(--color-primary);">
                View the slides &rarr;
              </span>
            </a>

            {/* Deep Dives */}
            <a href={url("/research")} class="block p-4 rounded-lg transition-opacity hover:opacity-90" style="background: var(--color-surface); border: 1px solid var(--color-surface-light);">
              <div class="font-mono text-xs mb-2 tracking-widest uppercase" style="color: var(--color-text-dim);">
                Deep Dives
              </div>
              <div class="text-sm" style="color: var(--color-text-muted);">
                12 incident analyses, cost breakdowns, market data, and primary sources — all open source.
              </div>
              <span class="font-mono text-xs font-semibold mt-2 inline-block" style="color: var(--color-primary);">
                Browse the research library &rarr;
              </span>
            </a>

            {/* Incident Reports with map teasers */}
            <div class="rounded-lg overflow-hidden" style="border: 1px solid var(--color-surface-light);">
              <div class="px-4 py-3" style="background: var(--color-surface);">
                <div class="font-mono text-xs tracking-widest uppercase" style="color: var(--color-text-dim);">
                  Incident Reports
                </div>
              </div>
              <div class="flex flex-col">
                <a href={url("/research/incidents/2021-texas-ercot-winter-storm")} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-white/5" style="border-bottom: 1px solid var(--color-surface-light);">
                  <div class="flex-shrink-0 w-10 h-10 rounded flex items-center justify-center" style="background: rgba(239, 68, 68, 0.1);">
                    <div class="w-5 h-5 rounded-full" style="background: rgba(239, 68, 68, 0.6); box-shadow: 0 0 6px rgba(239, 68, 68, 0.3);"></div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold truncate" style="color: var(--color-text);">2021 Texas ERCOT</div>
                    <div class="text-xs truncate" style="color: var(--color-text-dim);">4.5M homes, 246 lives lost</div>
                  </div>
                  <span class="interactive-tag-text font-mono text-xs flex-shrink-0">Map</span>
                </a>
                <a href={url("/research/incidents/2025-iberian-peninsula-blackout")} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-white/5" style="border-bottom: 1px solid var(--color-surface-light);">
                  <div class="flex-shrink-0 w-10 h-10 rounded flex items-center justify-center" style="background: rgba(239, 68, 68, 0.1);">
                    <div class="w-5 h-5 rounded-full" style="background: rgba(239, 68, 68, 0.6); box-shadow: 0 0 6px rgba(239, 68, 68, 0.3);"></div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold truncate" style="color: var(--color-text);">2025 Iberian Blackout</div>
                    <div class="text-xs truncate" style="color: var(--color-text-dim);">60M people, 6 seconds</div>
                  </div>
                  <span class="interactive-tag-text font-mono text-xs flex-shrink-0">Map</span>
                </a>
                <a href={url("/research/incidents/2016-south-australia-blackout")} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-white/5" style="border-bottom: 1px solid var(--color-surface-light);">
                  <div class="flex-shrink-0 w-10 h-10 rounded flex items-center justify-center" style="background: rgba(239, 68, 68, 0.1);">
                    <div class="w-5 h-5 rounded-full" style="background: rgba(239, 68, 68, 0.6); box-shadow: 0 0 6px rgba(239, 68, 68, 0.3);"></div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold truncate" style="color: var(--color-text);">2016 South Australia</div>
                    <div class="text-xs truncate" style="color: var(--color-text-dim);">System black in 43 seconds</div>
                  </div>
                  <span class="interactive-tag-text font-mono text-xs flex-shrink-0">Map</span>
                </a>
                <a href={url("/research/incidents/2017-hornsdale-battery-response")} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-white/5" style="border-bottom: 1px solid var(--color-surface-light);">
                  <div class="flex-shrink-0 w-10 h-10 rounded flex items-center justify-center" style="background: rgba(16, 185, 129, 0.1);">
                    <div class="w-5 h-5 rounded-full" style="background: rgba(16, 185, 129, 0.6); box-shadow: 0 0 6px rgba(16, 185, 129, 0.3);"></div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold truncate" style="color: var(--color-text);">2017 Hornsdale Battery</div>
                    <div class="text-xs truncate" style="color: var(--color-success);">140ms response prevented cascade</div>
                  </div>
                  <span class="interactive-tag-text font-mono text-xs flex-shrink-0">Map</span>
                </a>
                <a href={url("/research")} class="flex items-center justify-center px-4 py-3 transition-colors hover:bg-white/5">
                  <span class="font-mono text-xs font-semibold" style="color: var(--color-primary);">
                    All 12 incidents &rarr;
                  </span>
                </a>
              </div>
            </div>

            {/* Enpal + Partners */}
            <div class="rounded-lg p-4 text-center" style="background: var(--color-surface); border: 1px solid var(--color-surface-light);">
              <a href="https://www.enpal.de" target="_blank" rel="noopener" class="inline-block hover:opacity-80 transition-opacity">
                <img src={url("/enpal-logo.svg")} alt="Enpal" class="h-20 mx-auto" />
              </a>
              <div class="text-sm mt-3" style="color: var(--color-text-dim);">
                Europe's largest residential solar + storage installer
              </div>
              <div class="flex justify-center gap-3 mt-3">
                <a href="https://www.enpal.de/solar" target="_blank" rel="noopener" class="font-mono text-xs px-3 py-1 rounded transition-opacity hover:opacity-80" style="background: rgba(16, 185, 129, 0.1); color: var(--color-success); border: 1px solid rgba(16, 185, 129, 0.2);">Get Solar</a>
                <a href="https://www.enpal.de/karriere" target="_blank" rel="noopener" class="font-mono text-xs px-3 py-1 rounded transition-opacity hover:opacity-80" style="background: rgba(34, 211, 238, 0.1); color: var(--color-primary); border: 1px solid rgba(34, 211, 238, 0.2);">Join the Team</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
