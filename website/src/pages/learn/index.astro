---
import ContentLayout from '../../layouts/ContentLayout.astro';
import InfoPanel from '../../components/InfoPanel.astro';
import { url } from '../../utils/url';

const modules = [
  { num: 1, title: 'How the Grid Works', desc: 'The 50 Hz heartbeat, supply = demand, and the 2.5 Hz between normal and collapse.', href: url('/learn/how-the-grid-works'), interactive: true },
  { num: 2, title: 'The Old Way', desc: 'Peaker plants, spinning reserves, and EUR 10B+/yr to keep the lights on.', href: url('/learn/the-old-way'), interactive: true },
  { num: 3, title: 'The Renewable Revolution', desc: 'Duck curves, curtailment, and throwing away clean energy.', href: url('/learn/the-renewable-revolution'), interactive: true },
  { num: 4, title: 'The Virtual Power Plant', desc: 'Homes as infrastructure. Batteries, EVs, and heat pumps stabilizing the grid.', href: url('/learn/the-virtual-power-plant'), interactive: true },
  { num: 5, title: 'The Future', desc: 'Grid resilience through distribution. Software eating the grid.', href: url('/learn/the-future'), interactive: false },
];
---

<ContentLayout title="Learn VPP" description="Five modules covering how the electricity grid works, why it's changing, and what comes next.">

<h1>Learn VPP</h1>

<p class="text-xl" style="color: var(--color-text-muted); max-width: 600px;">
  Five modules that take you from "what is 50 Hz?" to understanding how Virtual Power
  Plants are reshaping the grid.
</p>

<hr />

<div class="flex flex-col gap-4">
  {modules.map((m) => (
    <a
      href={m.href}
      class="group flex items-start gap-5 p-5 rounded-xl transition-all duration-200 hover:translate-x-1"
      style="background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);"
    >
      <div
        class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center font-mono font-bold text-lg"
        style="background: var(--color-surface); color: var(--color-primary);"
      >
        {m.num}
      </div>
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span class="font-semibold text-lg group-hover:text-white transition-colors" style="color: var(--color-text);">
            {m.title}
          </span>
          {m.interactive && (
            <span
              class="font-mono text-sm px-2 py-0.5 rounded"
              style="background: rgba(34, 211, 238, 0.1); color: var(--color-primary); border: 1px solid rgba(34, 211, 238, 0.2);"
            >
              Interactive
            </span>
          )}
        </div>
        <div class="text-sm" style="color: var(--color-text-dim);">
          {m.desc}
        </div>
      </div>
    </a>
  ))}
</div>

<InfoPanel label="Want to go deeper?" color="surface" class="mt-10">
  The <a href={url("/research")} style="color: var(--color-primary);">Research Library</a> has 12 detailed
  incident analyses, cost breakdowns, and primary sources behind everything in these modules.
</InfoPanel>

</ContentLayout>
