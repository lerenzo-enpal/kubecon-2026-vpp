---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../utils/url';

interface Section {
  id: string;
  title: string;
  interactive?: boolean;
}

interface Props {
  title: string;
  description?: string;
  sections?: Section[];
}

const { title, description, sections = [] } = Astro.props;

const modules = [
  {
    title: 'How the Grid Works',
    href: url('/learn/how-the-grid-works'),
    interactive: true,
    sections: [
      { id: 'the-grid-is-huge', title: 'The Grid is Huge' },
      { id: 'the-50-hz-heartbeat', title: 'The 50 Hz Heartbeat' },
      { id: 'supply--demand-every-second', title: 'Supply = Demand' },
      { id: '25-hz-between-normal-and-catastrophe', title: '2.5 Hz to Catastrophe' },
      { id: 'what-happens-when-balance-breaks', title: 'When Balance Breaks' },
      { id: 'try-to-break-the-grid', title: 'Try to Break the Grid!' },
    ],
  },
  {
    title: 'The Old Way',
    href: url('/learn/the-old-way'),
    interactive: true,
    sections: [
      { id: 'peaker-plants', title: 'Peaker Plants' },
      { id: 'spinning-reserves', title: 'Spinning Reserves' },
      { id: 'congestion', title: 'Grid Congestion' },
      { id: 'curtailment', title: 'Curtailment' },
      { id: 'real-incidents', title: 'Real Incidents' },
    ],
  },
  {
    title: 'The Renewable Revolution',
    href: url('/learn/the-renewable-revolution'),
    interactive: true,
    sections: [
      { id: 'growth', title: 'Solar & Wind Growth' },
      { id: 'duck-curve', title: 'The Duck Curve', interactive: true },
      { id: 'curtailment', title: 'Curtailment' },
      { id: 'negative-prices', title: 'Negative Prices' },
    ],
  },
  {
    title: 'The Virtual Power Plant',
    href: url('/learn/the-virtual-power-plant'),
    interactive: true,
    sections: [
      { id: 'what-is-a-vpp', title: 'What is a VPP?' },
      { id: 'homes-as-infrastructure', title: 'Homes as Infrastructure', interactive: true },
      { id: 'coordination', title: 'Real-Time Coordination' },
      { id: 'hornsdale', title: 'The Hornsdale Story' },
    ],
  },
  {
    title: 'The Future',
    href: url('/learn/the-future'),
    interactive: false,
    sections: [
      { id: 'distributed-resilience', title: 'Distributed Resilience' },
      { id: 'software-eating-the-grid', title: 'Software Eating the Grid' },
      { id: 'what-you-can-do', title: 'What You Can Do' },
    ],
  },
];

const currentPath = Astro.url.pathname;
// Use sections prop if provided, otherwise fall back to module definition
const activeSections = sections.length > 0 ? sections : (modules.find(m => currentPath.startsWith(m.href))?.sections || []);

const isResearch = currentPath.startsWith('/research');
const isResearchIncident = currentPath.includes('/research/incidents/');
const isResearchTopic = currentPath.includes('/research/topics/');

const incidents = [
  { year: '2003', title: 'Northeast US Blackout', short: 'NE US Blackout', slug: '2003-northeast-us-blackout', color: 'var(--color-danger)' },
  { year: '2003', title: 'Italy Blackout', short: 'Italy Blackout', slug: '2003-italy-blackout', color: 'var(--color-danger)' },
  { year: '2006', title: 'European Grid Split', short: 'EU Grid Split', slug: '2006-european-grid-split', color: 'var(--color-accent)' },
  { year: '2016', title: 'South Australia Blackout', short: 'SA Blackout', slug: '2016-south-australia-blackout', color: 'var(--color-danger)' },
  { year: '2017', title: 'Hornsdale Battery', short: 'Hornsdale', slug: '2017-hornsdale-battery-response', color: 'var(--color-success)' },
  { year: '2017', title: 'SA Heatwave', short: 'SA Heatwave', slug: '2017-south-australia-heatwave', color: 'var(--color-accent)' },
  { year: '2021', title: 'Texas Winter Storm', short: 'Texas ERCOT', slug: '2021-texas-ercot-winter-storm', color: 'var(--color-danger)' },
  { year: '2021', title: 'EU Grid Split', short: 'EU Grid Split', slug: '2021-european-grid-split', color: 'var(--color-accent)' },
  { year: '2024', title: 'Dunkelflaute', short: 'Dunkelflaute', slug: '2024-dunkelflaute-germany', color: 'var(--color-secondary)' },
  { year: '2025', title: 'Iberian Blackout', short: 'Iberian Blackout', slug: '2025-iberian-peninsula-blackout', color: 'var(--color-danger)' },
  { year: '2025', title: 'Berlin Arson', short: 'Berlin Arson', slug: '2025-berlin-johannisthal-arson', color: 'var(--color-accent)' },
  { year: '2026', title: 'Berlin Teltow Canal', short: 'Teltow Canal', slug: '2026-berlin-teltow-canal-arson', color: 'var(--color-accent)' },
];

const topics = [
  { title: 'Cascading Failures', slug: 'cascading-failures' },
  { title: 'Grid Flexibility Costs', slug: 'grid-flexibility-costs' },
  { title: 'German Curtailment', slug: 'german-grid-curtailment' },
  { title: 'Electricity Pricing', slug: 'electricity-pricing' },
  { title: 'Demand Response', slug: 'demand-response' },
  { title: 'VPP Market', slug: 'vpp-market' },
  { title: 'Grid Frequency', slug: 'grid-frequency' },
  { title: 'Enpal / Flexa', slug: 'enpal-flexa' },
];
---

<BaseLayout title={`${title} — Grid`} description={description}>
  <div class="min-h-screen flex flex-col">
    <SiteHeader />

    <div class="flex-1 flex max-w-7xl mx-auto w-full min-w-0">
      <!-- Sidebar TOC -->
      <aside class="hidden lg:block w-72 flex-shrink-0 py-8 pr-6 border-r" style="border-color: var(--color-surface-light);">
        <div class="sticky top-8">
          <a href={url("/learn")} class="block font-mono text-xs mb-4 hover:opacity-70 transition-opacity" style="color: var(--color-text-dim); letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;">
            Learn
          </a>
          <nav class="flex flex-col gap-0.5">
            {modules.map((m, i) => {
              const isActive = currentPath.startsWith(m.href);
              return (
                <div>
                  {/* Module title */}
                  <a
                    href={m.href}
                    class="flex items-center gap-2 px-3 py-2 rounded text-sm transition-colors"
                    style={isActive
                      ? `background: var(--color-surface); color: var(--color-text);`
                      : `color: var(--color-text-dim);`
                    }
                  >
                    <span
                      class="font-mono text-xs w-4 text-center flex-shrink-0"
                      style={isActive ? `color: var(--color-primary);` : ''}
                    >
                      {i + 1}
                    </span>
                    <span class={isActive ? 'font-medium' : ''}>{m.title}</span>
                    {m.interactive && (
                      <span class="ml-auto text-xs flex-shrink-0" style="color: var(--color-primary); opacity: 0.4;">*</span>
                    )}
                  </a>

                  {/* Expanded sections when active */}
                  {isActive && m.sections && m.sections.length > 0 && (
                    <div class="ml-4 pl-5 border-l mt-1 mb-2 flex flex-col gap-0.5" style="border-color: var(--color-surface-light);">
                      {m.sections.map((s) => (
                        <a
                          href={`#${s.id}`}
                          class="toc-section flex items-center gap-2 px-2 py-1.5 rounded text-sm transition-colors"
                          style="color: var(--color-text-dim);"
                          data-section={s.id}
                        >
                          <span>{s.title}</span>
                          {s.interactive && (
                            <span
                              class="font-mono text-xs px-1.5 py-0.5 rounded flex-shrink-0"
                              style="background: rgba(34, 211, 238, 0.08); color: var(--color-primary); border: 1px solid rgba(34, 211, 238, 0.15);"
                            >
                              Interactive
                            </span>
                          )}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              );
            })}
          </nav>

          <!-- Research Library -->
          <div class="mt-6 pt-4 border-t" style="border-color: var(--color-surface-light);">
            <div class="font-mono text-xs mb-3" style="color: var(--color-text-dim); letter-spacing: 0.1em; text-transform: uppercase;">
              Research
            </div>
            <div class="flex flex-col gap-0.5">
              <a href={url("/research")} class="px-3 py-1.5 rounded text-sm transition-colors" style={isResearch ? 'background: var(--color-surface); color: var(--color-text);' : 'color: var(--color-text-dim);'}>
                All Research
              </a>

              {/* Incidents — expandable */}
              <details class="group" open={isResearchIncident}>
                <summary class="px-3 py-1.5 rounded text-sm cursor-pointer select-none list-none flex items-center gap-1 transition-colors" style="color: var(--color-text-dim);">
                  <span class="text-xs transition-transform group-open:rotate-90" style="color: var(--color-text-dim);">&#9656;</span>
                  Grid Incidents
                  <span class="ml-auto font-mono text-xs" style="color: var(--color-surface-light);">12</span>
                </summary>
                <div class="ml-4 pl-3 border-l mt-0.5 mb-1 flex flex-col gap-0" style="border-color: var(--color-surface-light);">
                  {incidents.map((inc) => {
                    const isActiveInc = currentPath.includes(inc.slug);
                    return (
                      <a
                        href={url(`/research/incidents/${inc.slug}`)}
                        class="px-2 py-1.5 rounded text-sm transition-colors truncate"
                        style={isActiveInc
                          ? 'background: var(--color-surface); color: var(--color-text);'
                          : 'color: var(--color-text-dim);'
                        }
                        title={inc.title}
                      >
                        <span class="font-mono mr-1" style={`color: ${inc.color}; opacity: 0.6;`}>{inc.year}</span>
                        {inc.short}
                      </a>
                    );
                  })}
                </div>
              </details>

              {/* Topics — expandable */}
              <details class="group" open={isResearchTopic}>
                <summary class="px-3 py-1.5 rounded text-sm cursor-pointer select-none list-none flex items-center gap-1 transition-colors" style="color: var(--color-text-dim);">
                  <span class="text-xs transition-transform group-open:rotate-90" style="color: var(--color-text-dim);">&#9656;</span>
                  Deep Dives
                  <span class="ml-auto font-mono text-xs" style="color: var(--color-surface-light);">8</span>
                </summary>
                <div class="ml-4 pl-3 border-l mt-0.5 mb-1 flex flex-col gap-0" style="border-color: var(--color-surface-light);">
                  {topics.map((t) => {
                    const isActiveTopic = currentPath.includes(t.slug);
                    return (
                      <a
                        href={url(`/research/topics/${t.slug}`)}
                        class="px-2 py-1.5 rounded text-sm transition-colors truncate"
                        style={isActiveTopic
                          ? 'background: var(--color-surface); color: var(--color-text);'
                          : 'color: var(--color-text-dim);'
                        }
                        title={t.title}
                      >
                        {t.title}
                      </a>
                    );
                  })}
                </div>
              </details>
            </div>
          </div>

          <!-- KubeCon link -->
          <div class="mt-6 pt-4 border-t" style="border-color: var(--color-surface-light);">
            <a
              href={url("/slides/")}
              class="block p-3 rounded-lg transition-colors"
              style="background: rgba(34, 211, 238, 0.06); border: 1px solid rgba(34, 211, 238, 0.15);"
            >
              <div class="font-mono text-xs mb-1" style="color: var(--color-primary); letter-spacing: 0.1em; text-transform: uppercase;">
                KubeCon 2026
              </div>
              <div class="text-sm font-medium" style="color: var(--color-text);">
                View the Presentation
              </div>
              <div class="text-xs mt-1" style="color: var(--color-text-dim);">
                The talk that started this project
              </div>
            </a>
            <div class="flex flex-col gap-1.5 mt-3">
              <a href="https://www.enpal.de/solar" target="_blank" rel="noopener" class="flex items-center justify-between px-3 py-2 rounded text-xs transition-colors hover:bg-surface" style="color: var(--color-text-dim); background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);">
                <span>Get Solar</span>
                <span class="text-xs opacity-40">&#9656;</span>
              </a>
              <a href="https://www.enpal.de/karriere" target="_blank" rel="noopener" class="flex items-center justify-between px-3 py-2 rounded text-xs transition-colors hover:bg-surface" style="color: var(--color-text-dim); background: var(--color-bg-alt); border: 1px solid var(--color-surface-light);">
                <span>Work in Green Tech</span>
                <span class="text-xs opacity-40">&#9656;</span>
              </a>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 min-w-0 py-6 md:py-8 px-4 md:px-8 lg:px-12">
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>

    <SiteFooter />
  </div>

  <!-- Scroll-spy: highlight current section in TOC -->
  <script is:inline>
    (function() {
      const links = document.querySelectorAll('.toc-section');
      if (!links.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.style.color = 'var(--color-text-dim)');
            const active = document.querySelector(`.toc-section[data-section="${entry.target.id}"]`);
            if (active) {
              active.style.color = 'var(--color-text)';
              active.style.background = 'var(--color-surface)';
            }
          }
        });
        // Clean up non-active backgrounds
        links.forEach(l => {
          if (l.style.color !== 'var(--color-text)') {
            l.style.background = '';
          }
        });
      }, { rootMargin: '-20% 0px -60% 0px' });

      links.forEach(link => {
        const id = link.getAttribute('data-section');
        const target = document.getElementById(id);
        if (target) observer.observe(target);
      });
    })();
  </script>
</BaseLayout>
