---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import FontSizeToggle from '../components/FontSizeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const isIncident = currentPath.includes('/research/incidents/');
const isTopic = currentPath.includes('/research/topics/');

const incidents = [
  { year: '03', short: 'NE US Blackout', slug: '2003-northeast-us-blackout', color: 'var(--color-danger)' },
  { year: '03', short: 'Italy Blackout', slug: '2003-italy-blackout', color: 'var(--color-danger)' },
  { year: '06', short: 'EU Grid Split', slug: '2006-european-grid-split', color: 'var(--color-accent)' },
  { year: '16', short: 'SA Blackout', slug: '2016-south-australia-blackout', color: 'var(--color-danger)' },
  { year: '17', short: 'Hornsdale', slug: '2017-hornsdale-battery-response', color: 'var(--color-success)' },
  { year: '17', short: 'SA Heatwave', slug: '2017-south-australia-heatwave', color: 'var(--color-accent)' },
  { year: '21', short: 'Texas ERCOT', slug: '2021-texas-ercot-winter-storm', color: 'var(--color-danger)' },
  { year: '21', short: 'EU Grid Split', slug: '2021-european-grid-split', color: 'var(--color-accent)' },
  { year: '24', short: 'Dunkelflaute', slug: '2024-dunkelflaute-germany', color: 'var(--color-secondary)' },
  { year: '25', short: 'Iberian Blackout', slug: '2025-iberian-peninsula-blackout', color: 'var(--color-danger)' },
  { year: '25', short: 'Berlin Arson', slug: '2025-berlin-johannisthal-arson', color: 'var(--color-accent)' },
  { year: '26', short: 'Teltow Canal', slug: '2026-berlin-teltow-canal-arson', color: 'var(--color-accent)' },
];

const topics = [
  { title: 'Cascading Failures', slug: 'cascading-failures' },
  { title: 'Grid Flexibility Costs', slug: 'grid-flexibility-costs' },
  { title: 'German Curtailment', slug: 'german-grid-curtailment' },
  { title: 'Electricity Pricing', slug: 'electricity-pricing' },
  { title: 'Demand Response', slug: 'demand-response' },
  { title: 'VPP Market', slug: 'vpp-market' },
  { title: 'Grid Frequency', slug: 'grid-frequency' },
  { title: 'Enpal / Flexa', slug: 'enpal-flexa' },
];
---

<BaseLayout title={`${title} — Grid Research`} description={description}>
  <div class="min-h-screen flex flex-col">
    <header class="px-8 py-4 border-b" style="border-color: var(--color-surface-light);">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <div class="w-2 h-2 rounded-full" style="background: var(--color-primary); box-shadow: 0 0 8px var(--color-primary);"></div>
            <span class="font-mono font-bold" style="color: var(--color-text); letter-spacing: 0.05em;">GRID</span>
          </a>
          <nav class="flex gap-1 font-mono text-xs" style="color: var(--color-text-dim);">
            <a href="/research" class="hover:opacity-70 transition-opacity">Research</a>
            <span style="color: var(--color-surface-light);">/</span>
            <span style="color: var(--color-text-muted);">{title}</span>
          </nav>
        </div>
        <div class="flex items-center gap-6">
          <nav class="flex gap-6 font-mono text-sm" style="color: var(--color-text-dim);">
            <a href="/learn/how-the-grid-works" class="hover:opacity-70 transition-opacity">Learn</a>
            <a href="/research" class="hover:opacity-70 transition-opacity">Research</a>
          </nav>
          <FontSizeToggle />
          <ThemeToggle />
        </div>
      </div>
    </header>

    <div class="flex-1 flex max-w-7xl mx-auto w-full">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 flex-shrink-0 py-8 pr-6 border-r" style="border-color: var(--color-surface-light);">
        <div class="sticky top-8">
          {/* Learn section — always visible */}
          <div class="mb-4">
            <div class="font-mono text-xs mb-2" style="color: var(--color-text-dim); letter-spacing: 0.1em; text-transform: uppercase;">
              Learn
            </div>
            <nav class="flex flex-col gap-0.5">
              <a href="/learn/how-the-grid-works" class="px-3 py-1.5 rounded text-sm transition-colors" style="color: var(--color-text-dim);">How the Grid Works</a>
              <a href="/learn/the-old-way" class="px-3 py-1.5 rounded text-sm transition-colors" style="color: var(--color-text-dim);">The Old Way</a>
              <a href="/learn/the-renewable-revolution" class="px-3 py-1.5 rounded text-sm transition-colors" style="color: var(--color-text-dim);">The Renewable Revolution</a>
              <a href="/learn/the-virtual-power-plant" class="px-3 py-1.5 rounded text-sm transition-colors" style="color: var(--color-text-dim);">The Virtual Power Plant</a>
              <a href="/learn/the-future" class="px-3 py-1.5 rounded text-sm transition-colors" style="color: var(--color-text-dim);">The Future</a>
            </nav>
          </div>

          <div class="font-mono text-xs mb-3" style="color: var(--color-text-dim); letter-spacing: 0.1em; text-transform: uppercase;">
            Research
          </div>

          <a href="/research" class="px-3 py-1.5 rounded text-sm block mb-2 transition-colors" style="color: var(--color-text-dim);">
            All Research
          </a>

          {/* Incidents */}
          <details class="group" open={isIncident}>
            <summary class="px-3 py-1.5 rounded text-xs cursor-pointer select-none list-none flex items-center gap-1 transition-colors" style="color: var(--color-text-dim);">
              <span class="text-[10px] transition-transform group-open:rotate-90" style="color: var(--color-text-dim);">&#9656;</span>
              Grid Incidents
              <span class="ml-auto font-mono text-[10px]" style="color: var(--color-surface-light);">12</span>
            </summary>
            <div class="ml-4 pl-3 border-l mt-0.5 mb-1 flex flex-col gap-0" style="border-color: var(--color-surface-light);">
              {incidents.map((inc) => {
                const active = currentPath.includes(inc.slug);
                return (
                  <a
                    href={`/research/incidents/${inc.slug}`}
                    class="px-2 py-1 rounded text-[11px] transition-colors truncate"
                    style={active
                      ? 'background: var(--color-surface); color: var(--color-text);'
                      : 'color: var(--color-text-dim);'
                    }
                  >
                    <span class="font-mono mr-1" style={`color: ${inc.color}; opacity: 0.6;`}>{inc.year}</span>
                    {inc.short}
                  </a>
                );
              })}
            </div>
          </details>

          {/* Topics */}
          <details class="group" open={isTopic}>
            <summary class="px-3 py-1.5 rounded text-xs cursor-pointer select-none list-none flex items-center gap-1 transition-colors" style="color: var(--color-text-dim);">
              <span class="text-[10px] transition-transform group-open:rotate-90" style="color: var(--color-text-dim);">&#9656;</span>
              Deep Dives
              <span class="ml-auto font-mono text-[10px]" style="color: var(--color-surface-light);">8</span>
            </summary>
            <div class="ml-4 pl-3 border-l mt-0.5 mb-1 flex flex-col gap-0" style="border-color: var(--color-surface-light);">
              {topics.map((t) => {
                const active = currentPath.includes(t.slug);
                return (
                  <a
                    href={`/research/topics/${t.slug}`}
                    class="px-2 py-1 rounded text-[11px] transition-colors truncate"
                    style={active
                      ? 'background: var(--color-surface); color: var(--color-text);'
                      : 'color: var(--color-text-dim);'
                    }
                  >
                    {t.title}
                  </a>
                );
              })}
            </div>
          </details>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 py-8 px-8 lg:px-12">
        <div class="max-w-3xl">
          <article class="prose">
            <slot />
          </article>
        </div>
      </main>
    </div>

    <footer class="px-8 py-4 border-t" style="border-color: var(--color-surface-light);">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/research" class="font-mono text-xs hover:opacity-70 transition-opacity" style="color: var(--color-text-dim);">
          Back to Research Library
        </a>
        <div class="font-mono text-xs" style="color: var(--color-text-dim);">
          Open source research
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
