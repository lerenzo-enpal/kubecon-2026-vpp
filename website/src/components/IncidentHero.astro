---
interface Props {
  title: string;
  date: string;
  location: string;
  keyStat: string;
  keyStatLabel: string;
  severity: 'blackout' | 'near-miss' | 'price-event' | 'success' | 'attack';
}

const { title, date, location, keyStat, keyStatLabel, severity } = Astro.props;

const severityColors: Record<string, { bg: string; border: string; badge: string; label: string }> = {
  'blackout': { bg: 'rgba(239, 68, 68, 0.06)', border: 'var(--color-danger)', badge: 'rgba(239, 68, 68, 0.15)', label: 'Blackout' },
  'near-miss': { bg: 'rgba(245, 158, 11, 0.06)', border: 'var(--color-accent)', badge: 'rgba(245, 158, 11, 0.15)', label: 'Near-Miss' },
  'price-event': { bg: 'rgba(167, 139, 250, 0.06)', border: 'var(--color-secondary)', badge: 'rgba(167, 139, 250, 0.15)', label: 'Price Event' },
  'success': { bg: 'rgba(16, 185, 129, 0.06)', border: 'var(--color-success)', badge: 'rgba(16, 185, 129, 0.15)', label: 'Success Story' },
  'attack': { bg: 'rgba(245, 158, 11, 0.06)', border: 'var(--color-accent)', badge: 'rgba(245, 158, 11, 0.15)', label: 'Infrastructure Attack' },
};

const s = severityColors[severity] || severityColors['blackout'];
---

<div class="mb-10 rounded-xl overflow-hidden" style={`background: ${s.bg}; border: 1px solid ${s.border}30;`}>
  <!-- Severity stripe -->
  <div class="h-1" style={`background: linear-gradient(90deg, ${s.border}, ${s.border}60, transparent);`}></div>

  <div class="p-8">
    <div class="flex items-start justify-between flex-wrap gap-6">
      <div>
        <!-- Badge -->
        <span
          class="inline-block font-mono text-xs font-semibold px-3 py-1 rounded-full mb-4"
          style={`background: ${s.badge}; color: ${s.border}; border: 1px solid ${s.border}30;`}
        >
          {s.label}
        </span>

        <h1 class="text-4xl font-extrabold leading-tight mb-2" style="color: var(--color-text);">
          {title}
        </h1>

        <div class="flex items-center gap-4 font-mono text-sm" style="color: var(--color-text-dim);">
          <span>{date}</span>
          <span style={`color: ${s.border}40;`}>|</span>
          <span>{location}</span>
        </div>
      </div>

      <!-- Key stat -->
      <div class="text-right">
        <div
          class="font-mono font-extrabold text-4xl leading-none"
          style={`color: ${s.border}; text-shadow: 0 0 20px ${s.border}30;`}
        >
          {keyStat}
        </div>
        <div class="font-mono text-xs mt-2" style="color: var(--color-text-dim); letter-spacing: 0.08em; text-transform: uppercase;">
          {keyStatLabel}
        </div>
      </div>
    </div>
  </div>
</div>
